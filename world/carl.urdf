<?xml version="1.0"?>
<robot name="carl_elite">
  <material name="chassis_color">
    <color rgba="0.15 0.15 0.18 1"/> <!-- Dark graphite -->
  </material>
  <material name="wheel_tire">
    <color rgba="0.05 0.05 0.05 1"/> <!-- Matte black -->
  </material>
  <material name="wheel_hub">
    <color rgba="0.0 0.8 0.8 1"/> <!-- Cyan glow -->
  </material>
  <material name="neck_color">
    <color rgba="0.8 0.8 0.85 1"/> <!-- Silver aluminum -->
  </material>
  
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.12 0.16 0.04"/> <!-- Sleeker chassis -->
      </geometry>
      <material name="chassis_color"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.12 0.16 0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.002"/>
    </inertial>
  </link>

  <!-- Left Wheel -->
  <link name="left_wheel">
    <visual>
      <origin rpy="1.570796 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.025" radius="0.07"/> <!-- Larger wheels -->
      </geometry>
      <material name="wheel_tire"/>
    </visual>
    <!-- Visual hub -->
    <visual>
      <origin rpy="1.570796 0 0" xyz="0 0.013 0"/>
      <geometry>
        <cylinder length="0.002" radius="0.03"/>
      </geometry>
      <material name="wheel_hub"/>
    </visual>
    <collision>
      <origin rpy="1.570796 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.025" radius="0.07"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.0003" ixy="0" ixz="0" iyy="0.0003" iyz="0" izz="0.0005"/>
    </inertial>
  </link>
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0 0.095 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- Right Wheel -->
  <link name="right_wheel">
    <visual>
      <origin rpy="1.570796 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.025" radius="0.07"/>
      </geometry>
      <material name="wheel_tire"/>
    </visual>
    <visual>
      <origin rpy="1.570796 0 0" xyz="0 -0.013 0"/>
      <geometry>
        <cylinder length="0.002" radius="0.03"/>
      </geometry>
      <material name="wheel_hub"/>
    </visual>
    <collision>
      <origin rpy="1.570796 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.025" radius="0.07"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.0003" ixy="0" ixz="0" iyy="0.0003" iyz="0" izz="0.0005"/>
    </inertial>
  </link>
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0 -0.095 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- Flexible Neck Base (Pitch Joint) -->
  <link name="neck_link">
    <visual>
      <origin xyz="0 0 0.2" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.4" radius="0.008"/> <!-- Thin, long neck -->
      </geometry>
      <material name="neck_color"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.2" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.4" radius="0.008"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.2" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.0013" ixy="0" ixz="0" iyy="0.0013" iyz="0" izz="0.00001"/>
    </inertial>
  </link>
  <joint name="neck_joint" type="revolute">
    <parent link="base_link"/>
    <child link="neck_link"/>
    <origin xyz="0 0 0.02" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.3" upper="0.3" effort="20.0" velocity="10.0"/>
    <dynamics damping="0.1" friction="0.0"/>
  </joint>

  <!-- Heavy Head (The Brain Box) -->
  <link name="head_link">
    <visual>
      <geometry>
        <box size="0.1 0.1 0.08"/>
      </geometry>
      <material name="chassis_color"/>
    </visual>
    <!-- Visual Eye/Screen -->
    <visual>
      <origin xyz="0.051 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.002 0.06 0.04"/>
      </geometry>
      <material name="wheel_hub"/> <!-- Cyan screen/eye facing forward -->
    </visual>
    <collision>
      <geometry>
        <box size="0.1 0.1 0.08"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.5"/> <!-- Very top heavy -->
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.002"/>
    </inertial>
  </link>
  <joint name="head_joint" type="fixed">
    <parent link="neck_link"/>
    <child link="head_link"/>
    <origin xyz="0 0 0.4" rpy="0 0 0"/> <!-- Attached to top of 40cm neck -->
  </joint>

</robot>
